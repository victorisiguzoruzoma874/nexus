# =============================================================================
# NexusCare Backend Environment Configuration
# =============================================================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!

# =============================================================================
# ML Pipeline
# =============================================================================
# Python FastAPI ML service URL
ML_SERVICE_URL=http://localhost:8001
# Raw Bronze JSON blob storage path
RAW_STORAGE_PATH=./raw-storage

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# Base URL for the API (used in email notifications, etc.)
API_BASE_URL=http://localhost:8080

# =============================================================================
# PostgreSQL Database
# =============================================================================
DATABASE_URL=postgres://postgres:password@localhost:5432/nexuscare
DATABASE_MAX_CONNECTIONS=10
# Connection timeout in seconds
DATABASE_TIMEOUT_SECONDS=30

# =============================================================================
# JWT Authentication
# =============================================================================
# Generate a secure random string: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_secret_string_at_least_32_characters
JWT_EXPIRY_HOURS=24
# Refresh token expiry (in days)
JWT_REFRESH_EXPIRY_DAYS=30

# =============================================================================
# Encryption (AES-256-GCM for payment tokens)
# =============================================================================
# Generate a secure 32-byte key: openssl rand -base64 32
ENCRYPTION_KEY=change_me_to_a_32_byte_base64_encoded_key_for_aes256
# Salt for additional security (optional)
ENCRYPTION_SALT=change_me_to_a_random_salt_string

# =============================================================================
# SafeHaven (microfinance bank — payments + wallet)
# =============================================================================
# Leave SAFEHAVEN_BASE_URL empty to run in mock mode.
SAFEHAVEN_BASE_URL=https://api.safehavenmfb.com
SAFEHAVEN_CLIENT_ID=your_safehaven_client_id_here
# Signed RS256 JWT issued by SafeHaven; used as the OAuth2 client assertion
# and as the ClientID header on every authenticated call.
SAFEHAVEN_IBS_CLIENT_ID=your_safehaven_ibs_client_id_jwt_here
# Platform settlement account (debited for payouts; default settlement target
# for hospital deposit virtual accounts).
SAFEHAVEN_DEBIT_ACCOUNT_NUMBER=your_settlement_account_number
SAFEHAVEN_BANK_CODE=090286
# HMAC-SHA256 secret for verifying SafeHaven webhook signatures.
SAFEHAVEN_WEBHOOK_SECRET=your_safehaven_webhook_secret_here
# Public URL SafeHaven calls for virtual-account inflows; must point at our
# /api/v1/webhooks/safehaven endpoint.
SAFEHAVEN_CALLBACK_URL=https://your.public.host/api/v1/webhooks/safehaven

# =============================================================================
# Geocoding Service (Nominatim/OpenStreetMap)
# =============================================================================
# Base URL for geocoding API
GEOCODING_API_URL=https://nominatim.openstreetmap.org
# User agent (required by Nominatim - use your app name and contact)
GEOCODING_USER_AGENT=NexusCare/1.0 (contact@nexuscare.com)
# Rate limiting: requests per second (Nominatim limit is 1 req/sec)
GEOCODING_RATE_LIMIT=1
# Retry configuration
GEOCODING_MAX_RETRIES=3
GEOCODING_RETRY_DELAY_MS=1000

# =============================================================================
# Email Service (SMTP)
# =============================================================================
# SMTP server configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
# Sender email and name
SMTP_FROM_EMAIL=noreply@nexuscare.com
SMTP_FROM_NAME=NexusCare Platform
# Use TLS/STARTTLS
SMTP_USE_TLS=true

# Email outbox worker settings
EMAIL_OUTBOX_POLL_SECS=5
EMAIL_OUTBOX_BATCH_SIZE=20
EMAIL_OUTBOX_MAX_ATTEMPTS=5
EMAIL_OUTBOX_RETRY_BASE_MINUTES=5

# Alternative: SendGrid API (comment out SMTP if using SendGrid)
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=noreply@nexuscare.com
# SENDGRID_FROM_NAME=NexusCare Platform

# =============================================================================
# Push Notifications (Firebase Cloud Messaging)
# =============================================================================
# FCM Server Key from Firebase Console
FCM_SERVER_KEY=your_firebase_server_key_here
# FCM Project ID
FCM_PROJECT_ID=your_firebase_project_id
# Path to Firebase service account JSON file
FCM_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# =============================================================================
# File Storage (for document uploads)
# =============================================================================
# Storage provider: local, s3, azure, gcs
STORAGE_PROVIDER=local
# Local storage path (if using local storage)
STORAGE_LOCAL_PATH=./uploads
# Maximum file size in MB
STORAGE_MAX_FILE_SIZE_MB=10

# AWS S3 Configuration (if using S3)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=nexuscare-documents
# AWS_S3_ENDPOINT=https://s3.amazonaws.com

# =============================================================================
# Logging
# =============================================================================
# Log level: trace, debug, info, warn, error
RUST_LOG=nexuscare_backend=debug,tower_http=debug,sqlx=info
# Log format: json, pretty
LOG_FORMAT=pretty
# Log to file (optional)
LOG_FILE_PATH=./logs/nexuscare.log

# =============================================================================
# CORS Configuration
# =============================================================================
# Allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Allow credentials
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# Rate Limiting
# =============================================================================
# Requests per minute per IP
RATE_LIMIT_PER_MINUTE=60
# Burst size
RATE_LIMIT_BURST=10

# =============================================================================
# Application Settings
# =============================================================================
# Environment: development, staging, production
APP_ENV=development
# Enable API documentation (Swagger)
ENABLE_API_DOCS=true
# Enable request logging
ENABLE_REQUEST_LOGGING=true
# Service radius for hospitals (in kilometers)
DEFAULT_SERVICE_RADIUS_KM=5.0

# =============================================================================
# Security
# =============================================================================
# Bcrypt work factor (10-14 recommended, higher = more secure but slower)
BCRYPT_COST=12
# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30
# Maximum login attempts before lockout
MAX_LOGIN_ATTEMPTS=5
# Lockout duration in minutes
LOCKOUT_DURATION_MINUTES=15
